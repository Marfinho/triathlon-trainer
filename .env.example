# ----------------------------------------------------------------------------
# LocalHub – Beispiel-Umgebungsvariablen
# Kopiere diese Datei nach `.env` und passe die Werte an.
# Committe niemals echte Secrets oder die `.env`-Datei selbst.
# ----------------------------------------------------------------------------

DATABASE_URL="postgresql://user:password@localhost:5432/localhub"
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_MONTHLY=""
STRIPE_PRICE_YEARLY=""
STRIPE_PRICE_LIFETIME=""
ENCRYPTION_KEY="generate-with-openssl-rand-base64-32"
CRON_SECRET="generate-with-openssl-rand-base64-32"
INTERVALS_ATHLETE_ID=""
INTERVALS_API_KEY=""
INTERVALS_API_BASE_URL="https://intervals.icu/api/v1"

# Optionale direkte LLM-Anbindung für die Plan-Generierung (sonst bleibt der
# manuelle Copy-Paste-Workflow aktiv). Reihenfolge bei mehreren gesetzten:
# Ollama > Anthropic > OpenAI (lokal vor Cloud).
# Lokale Ollama-Instanz (https://ollama.com) als kostenlose Alternative ohne
# Cloud-API-Key – z.B. "http://localhost:11434" oder "http://ollama:11434" im
# Docker-Netz. Daten verlassen dabei nie die eigene Infrastruktur.
OLLAMA_BASE_URL=""
OLLAMA_MODEL="llama3.1"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-6"
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"

# OAuth2-Integrationen (optional – ohne diese Werte bleibt "Verbinden" inaktiv).
# Redirect-URI bei jedem Anbieter registrieren: ${NEXTAUTH_URL}/api/integrations/<provider>/callback
STRAVA_CLIENT_ID=""
STRAVA_CLIENT_SECRET=""
WAHOO_CLIENT_ID=""
WAHOO_CLIENT_SECRET=""
WITHINGS_CLIENT_ID=""
WITHINGS_CLIENT_SECRET=""
POSTGRES_DB="localhub"
POSTGRES_USER="localhub"
POSTGRES_PASSWORD="localhub"
SEED_ON_START="false"
