# ----------------------------------------------------------------------------
# LocalHub – Beispiel-Umgebungsvariablen
# Kopiere diese Datei nach `.env` und passe die Werte an.
# Committe niemals echte Secrets oder die `.env`-Datei selbst.
# ----------------------------------------------------------------------------

# Datenbank
# Lokale Entwicklung nutzt SQLite. Für einen späteren Wechsel auf PostgreSQL
# genügt es, den Provider in prisma/schema.prisma auf "postgresql" zu setzen
# und hier eine Postgres-URL zu hinterlegen, z.B.:
#   DATABASE_URL="postgresql://user:pass@localhost:5432/localhub?schema=public"
DATABASE_URL="file:./dev.db"

# Intervals.icu Integration
# API-Key findest du unter https://intervals.icu/settings (Developer Settings).
# Die Athlete-ID hat das Format "i12345".
INTERVALS_ATHLETE_ID=""
INTERVALS_API_KEY=""

# Basis-URL der Intervals.icu REST API (i.d.R. unverändert lassen)
INTERVALS_API_BASE_URL="https://intervals.icu/api/v1"
