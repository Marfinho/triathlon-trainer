// LocalHub Prisma Schema (PostgreSQL, Multi-User)
//
// - PostgreSQL als Provider; DATABASE_URL aus der Umgebung.
// - JSON wird als nativer `Json`-Typ gespeichert (kein String/Serialisierung).
// - Multi-User: jedes Domänen-Modell hat `userId` + Relation auf `User`.
//   ALLE Queries filtern verpflichtend nach `userId`.
// - Auth.js (NextAuth v5) Modelle: User, Account, Session, VerificationToken.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Auth & Account
// ---------------------------------------------------------------------------

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  emailVerified        DateTime?
  image                String?
  passwordHash         String?
  provider             String? // "google" | "credentials"
  providerId           String?
  role                 String    @default("user") // "user" | "admin"
  plan                 String    @default("free") // "free" | "paid"
  planInterval         String? // "monthly" | "yearly" | "lifetime"
  stripeCustomerId     String?
  stripeSubscriptionId String?
  planExpiresAt        DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  integrations UserIntegration[]

  athleteProfiles     AthleteProfile[]
  raceEvents          RaceEvent[]
  plannedWorkouts     PlannedWorkout[]
  actualActivities    ActualActivity[]
  trainingPlanImports TrainingPlanImport[]
  coachSummaryExports CoachSummaryExport[]
  intervalsSyncs      IntervalsWorkoutSync[]
  syncQueueJobs       SyncQueue[]
  syncLogs            SyncLog[]
  readinessSnapshots  ReadinessSnapshot[]
  painSnapshots       PainSnapshot[]
  gearItems           GearItem[]
  journalEntries      JournalEntry[]
  bodyMetrics         BodyMetric[]
  trainingGoals       TrainingGoal[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/// Globale, vom Admin editierbare Plan-Limit-Overrides je Tier.
/// `settingsJson` ist eine partielle Map der PLAN_LIMITS-Felder; `null` als
/// Wert bedeutet "unbegrenzt" (= Infinity), da JSON kein Infinity kennt.
model PlanOverride {
  id           String   @id @default(cuid())
  tier         String   @unique // "free" | "paid"
  settingsJson Json
  updatedAt    DateTime @updatedAt
  updatedBy    String?
}

/// Verschlüsselte Drittanbieter-Zugangsdaten (z.B. Intervals.icu).
model UserIntegration {
  id        String   @id @default(cuid())
  userId    String
  provider  String // "intervals"
  apiKey    String // AES-256-GCM-verschlüsselt
  athleteId String?
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Stammdaten
// ---------------------------------------------------------------------------

model AthleteProfile {
  id                    String   @id @default(cuid())
  userId                String
  name                  String
  heightCm              Int?
  weightKg              Float?
  ftpWatts              Int?
  thresholdHr           Int?
  thresholdPaceSecPerKm Int?
  thresholdSwimPer100m  Int?
  trainingLevel         String?
  primarySports         Json? // z.B. ["run","bike","swim"]
  knownLimiters         Json?
  equipment             Json?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model RaceEvent {
  id              String   @id @default(cuid())
  userId          String
  name            String
  date            DateTime
  type            String
  distance        String?
  priority        String?
  notes           String?
  completed       Boolean  @default(false)
  resultSeconds   Int?
  resultPlacement Int?
  resultNote      String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ---------------------------------------------------------------------------
// Geplante Workouts (LocalHub ist hier führend)
// ---------------------------------------------------------------------------

model PlannedWorkout {
  id                 String   @id @default(cuid())
  userId             String
  date               DateTime
  sport              String
  title              String
  plannedDurationMin Int      @default(0)
  plannedDistanceM   Int?
  rpe                Int?
  description        String?
  segmentsJson       Json     @default("[]") // Json-Array von Segmenten
  status             String   @default("planned")
  source             String   @default("plan_import")
  planImportId       String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user          User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  planImport    TrainingPlanImport?   @relation(fields: [planImportId], references: [id])
  intervalsSync IntervalsWorkoutSync?
  syncQueueJobs SyncQueue[]

  @@index([userId])
  @@index([date])
  @@index([status])
  @@index([planImportId])
}

// ---------------------------------------------------------------------------
// Ist-Aktivitäten – UNANTASTBAR.
// ---------------------------------------------------------------------------

model ActualActivity {
  id          String   @id @default(cuid())
  userId      String
  externalId  String?
  source      String   @default("intervals")
  date        DateTime
  sport       String
  durationMin Float?
  distanceKm  Float?
  distanceM   Float?
  load        Float?
  rpe         Float?
  avgHr       Int?
  notes       String?
  rawJson     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, source, externalId])
  @@index([userId])
  @@index([date])
}

// ---------------------------------------------------------------------------
// Planimport & CoachSummary-Export
// ---------------------------------------------------------------------------

model TrainingPlanImport {
  id                   String    @id @default(cuid())
  userId               String
  schemaVersion        String
  type                 String
  planName             String?
  generatedAt          DateTime?
  planStart            DateTime
  planDays             Int
  planEnd              DateTime
  rawJson              Json
  validationStatus     String
  validationErrorsJson Json?
  createdAt            DateTime  @default(now())

  user            User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  plannedWorkouts PlannedWorkout[]

  @@index([userId])
}

model CoachSummaryExport {
  id                     String    @id @default(cuid())
  userId                 String
  schemaVersion          String
  exportPurpose          String
  requestedFormat        String
  planStart              DateTime?
  planDays               Int?
  includedModulesJson    Json
  modulesJson            Json
  chatGptInstructionJson Json
  createdAt              DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Intervals.icu Synchronisation
// ---------------------------------------------------------------------------

model IntervalsWorkoutSync {
  id                         String    @id @default(cuid())
  userId                     String
  localWorkoutId             String    @unique
  intervalsEventId           String?
  intervalsActivityId        String?
  lastSyncedAt               DateTime?
  lastSyncedHash             String?
  syncStatus                 String    @default("pending")
  syncConflictState          String?
  deletedOrSupersededAt      DateTime?
  supersededByLocalWorkoutId String?
  createdAt                  DateTime  @default(now())
  updatedAt                  DateTime  @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  localWorkout PlannedWorkout @relation(fields: [localWorkoutId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([intervalsEventId])
}

model SyncQueue {
  id               String    @id @default(cuid())
  userId           String
  localWorkoutId   String
  intervalsEventId String?
  action           String
  payloadJson      Json?
  status           String    @default("pending")
  attempts         Int       @default(0)
  lastAttemptAt    DateTime?
  errorMessage     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  localWorkout PlannedWorkout @relation(fields: [localWorkoutId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([localWorkoutId])
}

model SyncLog {
  id                String   @id @default(cuid())
  userId            String
  localWorkoutId    String?
  intervalsEventId  String?
  action            String?
  type              String? // "sync" | "backup" | ...
  status            String?
  durationMs        Int?
  previousStateJson Json?
  newStateJson      Json?
  reason            String?
  triggeredBy       String?
  success           Boolean  @default(true)
  errorMessage      String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([localWorkoutId])
  @@index([type])
  @@index([createdAt])
}

// ---------------------------------------------------------------------------
// Optionale Snapshots (Readiness & Schmerz)
// ---------------------------------------------------------------------------

model ReadinessSnapshot {
  id                String   @id @default(cuid())
  userId            String
  date              DateTime
  status            String?
  sleepTrend        String?
  hrvTrend          String?
  restingHrTrend    String?
  subjectiveFatigue Int?
  notes             String?
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model PainSnapshot {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  overall   Int?
  knee      Int?
  achilles  Int?
  calf      Int?
  back      Int?
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

// ---------------------------------------------------------------------------
// Sportgeräte-Tracking
// ---------------------------------------------------------------------------

model GearItem {
  id           String    @id @default(cuid())
  userId       String
  name         String
  type         String
  sport        String?
  parentId     String?
  brand        String?
  model        String?
  purchaseDate DateTime?
  retired      Boolean   @default(false)
  autoTrack    Boolean   @default(true)
  manualKm     Float     @default(0)
  manualHours  Float     @default(0)
  alertKm      Float?
  alertHours   Float?
  notes        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent     GearItem?  @relation("GearComponents", fields: [parentId], references: [id], onDelete: Cascade)
  components GearItem[] @relation("GearComponents")

  @@index([userId])
  @@index([type])
  @@index([parentId])
}

model JournalEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  mood      Int?
  text      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model BodyMetric {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime
  weightKg  Float?
  restingHr Int?
  notes     String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
}

model TrainingGoal {
  id              String   @id @default(cuid())
  userId          String
  sport           String
  weeklyTargetMin Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, sport])
  @@index([userId])
}
